# NB : PAS de X-Robots-Tag noindex sur /* → on VEUT être indexé par Google.
# (le noindex ne bloque pas les scrapers, il ne fait que nous retirer de Google ;
#  la vraie protection anti-aspiration est assurée par Cloudflare.)
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), microphone=(), camera=(), browsing-topics=()
  Content-Security-Policy: frame-ancestors 'none'
  Cross-Origin-Resource-Policy: same-site

# data.js : on décourage le cache partagé et l'usage hors-site.
/data.js
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store
